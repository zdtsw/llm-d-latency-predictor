FROM registry.access.redhat.com/ubi9/python-312:latest@sha256:dad2d6acf3f5e48d26abf9dbdea2f2bab3b02c62d1d6e9e0330c8d43f0c3bfb4

USER root

RUN dnf install -y libgomp && dnf clean all

WORKDIR /app

COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

COPY pyproject.toml README.md ./
COPY src ./src
RUN pip install --no-cache-dir --no-deps .

RUN mkdir -p /local_models && chown 1001:1001 /local_models

EXPOSE 8001

ENV UVICORN_WORKERS=8

USER 1001:1001

CMD ["sh", "-c", "uvicorn llm_d_latency_predictor.prediction_server:app --host 0.0.0.0 --port 8001 --workers $UVICORN_WORKERS"]

LABEL com.redhat.component="odh-latency-predictor-prediction" \
      name="odh-latency-predictor-prediction" \
      description="Latency prediction server for llm-d" \
      summary="Serves online ML-based TTFT/TPOT latency predictions" \
      io.k8s.display-name="odh-latency-predictor-prediction" \
      io.k8s.description="Latency prediction server for llm-d"
