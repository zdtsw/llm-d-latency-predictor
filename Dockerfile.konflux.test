FROM registry.access.redhat.com/ubi9/python-312:latest@sha256:37c869e16388c960d533f317c48e2cad8e80561b0c6b59e697e38e7e9d103b9b

USER root

RUN dnf install -y jq && dnf clean all

WORKDIR /app

COPY requirements.txt ./
RUN pip install --no-cache-dir --no-deps -r requirements.txt

COPY tests ./tests

RUN mkdir -p /test-results

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1

USER 1001:1001

CMD ["pytest", "-v", "-s", "tests/test_dual_server_client.py"]

LABEL com.redhat.component="odh-latency-predictor-test" \
      name="odh-latency-predictor-test" \
      description="Test harness for llm-d latency predictor" \
      summary="Integration tests for latency prediction training and prediction servers" \
      io.k8s.display-name="odh-latency-predictor-test" \
      io.k8s.description="Test harness for llm-d latency predictor"
